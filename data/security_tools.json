        "category": "exploit"
      },
      "searchsploit": {
        "desc": "Exploit-DB search tool",
        "install": "apt install exploitdb / brew install exploitdb",
        "usage": "searchsploit apache 2.4",
        "category": "exploit"
      },
      "hydra": {
        "desc": "Password brute-forcing tool",
